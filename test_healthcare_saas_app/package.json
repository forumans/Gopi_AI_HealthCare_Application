{
  "name": "test_healthcare_saas_app",
  "version": "1.0.0",
  "description": "Centralized testing workspace for backend unit, frontend unit, integration, and E2E suites",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:unit:backend && npm run test:unit:frontend && npm run test:integration && npm run test:e2e",
    "test:db:check": "set DATABASE_URL=postgresql+asyncpg://test_user:password@localhost/test_healthcare_db&& python tests/db_connection_test.py",
    "test:unit:backend": "set DATABASE_URL=postgresql+asyncpg://test_user:password@localhost/test_healthcare_db&& set PYTHONPATH=..&& python -m unittest discover -s ../backend/tests -p \"test_*.py\"",
    "test:unit:frontend": "npm --prefix ../frontend run test -- src/components/pages/systemDashboardStats.test.ts",
    "test:integration": "playwright test --project=integration",
    "test:e2e": "playwright test --project=e2e",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:install": "playwright install"
  },
  "keywords": [
    "e2e",
    "testing",
    "playwright",
    "healthcare",
    "saas",
    "automation"
  ],
  "author": "Healthcare Testing Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.8.0",
    "playwright": "^1.40.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/healthcare/test-healthcare-saas-app.git"
  },
  "bugs": {
    "url": "https://github.com/healthcare/test-healthcare-saas-app/issues"
  },
  "homepage": "https://github.com/healthcare/test-healthcare-saas-app#readme"
}
