{
  "Type": "AWS::ElasticLoadBalancingV2::LoadBalancer",
  "Properties": {
    "Name": "healthcare-backend-alb",
    "Scheme": "internet-facing",
    "Type": "application",
    "IpAddressType": "ipv4",
    "VpcId": "vpc-xxxxxxxxx",
    "Subnets": [
      "subnet-xxxxxxxxx",
      "subnet-xxxxxxxxx",
      "subnet-xxxxxxxxx"
    ],
    "SecurityGroups": [
      "sg-xxxxxxxxx"
    ],
    "LoadBalancerAttributes": [
      {
        "Key": "deletion_protection.enabled",
        "Value": "false"
      },
      {
        "Key": "access_logs.s3.enabled",
        "Value": "true"
      },
      {
        "Key": "access_logs.s3.bucket",
        "Value": "healthcare-alb-logs"
      },
      {
        "Key": "idle_timeout.timeout_seconds",
        "Value": "60"
      }
    ],
    "Tags": [
      {
        "Key": "Environment",
        "Value": "production"
      },
      {
        "Key": "Application",
        "Value": "healthcare-backend"
      }
    ]
  }
}
