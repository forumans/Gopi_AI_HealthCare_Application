{
  "ApplicationLoadBalancerSecurityGroup": {
    "Type": "AWS::EC2::SecurityGroup",
    "Properties": {
      "GroupName": "healthcare-alb-sg",
      "GroupDescription": "Security group for healthcare application load balancer",
      "VpcId": "vpc-xxxxxxxxx",
      "SecurityGroupIngress": [
        {
          "IpProtocol": "TCP",
          "FromPort": 80,
          "ToPort": 80,
          "CidrIp": "0.0.0.0/0"
        },
        {
          "IpProtocol": "TCP",
          "FromPort": 443,
          "ToPort": 443,
          "CidrIp": "0.0.0.0/0"
        }
      ],
      "SecurityGroupEgress": [
        {
          "IpProtocol": "-1",
          "CidrIp": "0.0.0.0/0"
        }
      ],
      "Tags": [
        {
          "Key": "Name",
          "Value": "healthcare-alb-sg"
        },
        {
          "Key": "Environment",
          "Value": "production"
        }
      ]
    }
  },
  "ECSSecurityGroup": {
    "Type": "AWS::EC2::SecurityGroup",
    "Properties": {
      "GroupName": "healthcare-ecs-sg",
      "GroupDescription": "Security group for healthcare ECS tasks",
      "VpcId": "vpc-xxxxxxxxx",
      "SecurityGroupIngress": [
        {
          "IpProtocol": "TCP",
          "FromPort": 8000,
          "ToPort": 8000,
          "SourceSecurityGroupId": { "Ref": "ApplicationLoadBalancerSecurityGroup" }
        }
      ],
      "SecurityGroupEgress": [
        {
          "IpProtocol": "TCP",
          "FromPort": 5432,
          "ToPort": 5432,
          "DestinationSecurityGroupId": { "Ref": "RDSSecurityGroup" }
        },
        {
          "IpProtocol": "-1",
          "CidrIp": "0.0.0.0/0"
        }
      ],
      "Tags": [
        {
          "Key": "Name",
          "Value": "healthcare-ecs-sg"
        },
        {
          "Key": "Environment",
          "Value": "production"
        }
      ]
    }
  },
  "RDSSecurityGroup": {
    "Type": "AWS::EC2::SecurityGroup",
    "Properties": {
      "GroupName": "healthcare-rds-sg",
      "GroupDescription": "Security group for healthcare RDS database",
      "VpcId": "vpc-xxxxxxxxx",
      "SecurityGroupIngress": [
        {
          "IpProtocol": "TCP",
          "FromPort": 5432,
          "ToPort": 5432,
          "SourceSecurityGroupId": { "Ref": "ECSSecurityGroup" }
        }
      ],
      "SecurityGroupEgress": [
        {
          "IpProtocol": "-1",
          "CidrIp": "0.0.0.0/0"
        }
      ],
      "Tags": [
        {
          "Key": "Name",
          "Value": "healthcare-rds-sg"
        },
        {
          "Key": "Environment",
          "Value": "production"
        }
      ]
    }
  }
}
