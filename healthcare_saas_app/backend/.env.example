# Healthcare Application Backend Environment Variables
# Copy this file to .env and update with your actual values

# Database Configuration
# DATABASE_URL=postgresql+asyncpg://username:password@your-rds-endpoint:5432/healthcare_db


# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://api.your-domain.com

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production

# AWS Configuration (optional - for AWS Secrets Manager)
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ENABLED=false
JWT_SECRET_ARN=arn:aws:secretsmanager:us-east-1:account-id:secret:healthcare-jwt-secret
DATABASE_URL_ARN=arn:aws:secretsmanager:us-east-1:account-id:secret:healthcare-db-url

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring Configuration (optional)
SENTRY_DSN=your-sentry-dsn-for-error-tracking
ENABLE_METRICS=true

# Email Configuration (optional - for password reset, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# Application Configuration
APP_NAME=Healthcare SaaS Platform
APP_VERSION=1.0.0
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
