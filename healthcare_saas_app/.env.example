# Backend environment template (no real secrets)
# Copy to .env.local for local development

# Database Configuration
DATABASE_URL=postgresql+asyncpg://your_postgres_user:your_postgres_password@localhost:5432/healthcare_saas
TEST_DATABASE_URL=postgresql+asyncpg://your_postgres_user:your_postgres_password@localhost:5432/test_healthcare_db

# Security Configuration
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30

# CORS Configuration (local frontend dev URLs)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Server Configuration
HOST=127.0.0.1
PORT=8000
