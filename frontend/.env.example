# Healthcare Application Frontend Environment Variables
# Copy this file to .env and update with your actual values

# API Configuration
VITE_API_BASE_URL=https://your-alb-domain.com/api
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Healthcare SaaS Platform
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Healthcare Management Platform

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_SENTRY=false

# Third-party Services (optional)
VITE_SENTRY_DSN=your-sentry-dsn-for-frontend-error-tracking
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Development Configuration
VITE_DEV_MODE=false
VITE_MOCK_API=false

# UI Configuration
VITE_THEME=healthcare
VITE_DEFAULT_LANGUAGE=en

# Performance Configuration
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_TIMEOUT=300000  # 5 minutes in milliseconds
